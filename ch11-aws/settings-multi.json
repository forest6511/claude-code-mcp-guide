{
  "mcpServers": {
    "aws-serverless": {
      "command": "uvx",
      "args": ["awslabs-serverless-mcp-server"],
      "env": {
        "AWS_PROFILE": "dev",
        "AWS_DEFAULT_REGION": "ap-northeast-1"
      }
    },
    "aws-cloudwatch": {
      "command": "uvx",
      "args": ["awslabs-cloudwatch-mcp-server"],
      "env": {
        "AWS_PROFILE": "dev",
        "AWS_DEFAULT_REGION": "ap-northeast-1"
      }
    },
    "aws-dynamodb": {
      "command": "uvx",
      "args": ["awslabs-dynamodb-mcp-server"],
      "env": {
        "AWS_PROFILE": "dev",
        "AWS_DEFAULT_REGION": "ap-northeast-1"
      }
    }
  }
}
